# Supabase
DATABASE_URL="postgresql://postgres:password@db.xxx.supabase.co:5432/postgres"
NEXT_PUBLIC_SUPABASE_URL="https://xxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# VHSys (migration)
VHSYS_ACCESS_TOKEN=""
VHSYS_SECRET_TOKEN=""

# Fiscal (Focus NFe)
FOCUS_NFE_API_KEY=""
FOCUS_NFE_ENVIRONMENT="homologacao"

# Banco Inter
INTER_CLIENT_ID=""
INTER_CLIENT_SECRET=""
INTER_CERT_PATH=""
INTER_KEY_PATH=""

# Encryption
ENCRYPTION_KEY="generate-a-32-byte-hex-key"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# VOIP — Telefonia Sonax (F2.1 Click2Call)
# Token gerado no portal pabxcloud.sonax.net.br (Integrações).
# Ver Projetos Bot/Telefonia/API_SONAX_INTEGRACAO_ERP.md no repo squad.
SONAX_API_TOKEN=""

# Mapping email do user ERP -> ramal SIP (JSON inline).
# Ex: {"roberto@pontualtech.com.br":"101","daniela@pontualtech.com.br":"102"}
# Solução MVP F2.1; em F2.4 migra pra coluna voip_extensions.user_id.
SONAX_RAMAL_MAPPING="{}"
