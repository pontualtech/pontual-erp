;==============================================================================
; pjsip.conf — gerado em {{generatedAt}} por PontualERP
; NÃO editar manualmente — mudanças são sobrescritas em todo regenerate-config
;==============================================================================

;-- Transport global (host network = bind direto na interface pública) --------
[transport-udp]
type=transport
protocol=udp
bind=0.0.0.0:5060
; external_media_address e external_signaling_address NÃO necessários em host net

;-- Templates DRY pra ramais --------------------------------------------------
[ramal-template](!)
type=endpoint
transport=transport-udp
disallow=all
allow=ulaw,alaw
dtmf_mode=rfc4733
direct_media=no
rtp_symmetric=yes
force_rport=yes
rewrite_contact=yes

[aor-template](!)
type=aor
qualify_frequency=60

;==============================================================================
; PROVIDERS (trunks SIP por empresa)
;==============================================================================
{{#providers}}
;-- {{name}} ({{companyName}}) --
[trunk-{{tenantTag}}-out]
type=endpoint
transport=transport-{{transport}}
context={{contextInbound}}
tenantid={{tenantTag}}
disallow=all
{{#codecs}}allow={{.}}
{{/codecs}}dtmf_mode={{dtmfMode}}
direct_media=no
from_domain={{hostOutbound}}
{{#isIpBased}}
identify_by=ip
{{/isIpBased}}
aors=trunk-{{tenantTag}}-aor
{{#isUserSecret}}
outbound_auth=trunk-{{tenantTag}}-auth
{{/isUserSecret}}

[trunk-{{tenantTag}}-aor]
type=aor
contact=sip:{{hostOutbound}}:{{port}}
qualify_frequency={{qualifyFrequency}}

{{#isIpBased}}
[trunk-{{tenantTag}}-identify]
type=identify
endpoint=trunk-{{tenantTag}}-out
match={{matchIp}}
{{/isIpBased}}

{{#isUserSecret}}
[trunk-{{tenantTag}}-auth]
type=auth
auth_type=userpass
username={{username}}
password={{secretPlain}}

[trunk-{{tenantTag}}-reg]
type=registration
server_uri=sip:{{hostOutbound}}:{{port}}
client_uri=sip:{{username}}@{{hostOutbound}}:{{port}}
outbound_auth=trunk-{{tenantTag}}-auth
{{/isUserSecret}}

{{/providers}}

;==============================================================================
; EXTENSIONS (ramais SIP por empresa)
;==============================================================================
{{#extensions}}
[{{number}}](ramal-template)
context={{context}}
tenantid={{tenantTag}}
auth=auth-{{number}}
aors={{number}}
{{#callLimit}}
call_limit={{callLimit}}
{{/callLimit}}

[{{number}}](aor-template)
type=aor
max_contacts={{maxContacts}}

[auth-{{number}}]
type=auth
auth_type=userpass
username={{number}}
password={{secretPlain}}

{{/extensions}}